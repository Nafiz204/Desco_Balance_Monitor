# DESCO Prepaid Credentials
DESCO_USER=your_account_number
DESCO_PASS=your_password_optional_if_only_account_is_used
METER_NUMBER=your_meter_number

# Email Settings (for SMTP)
# EMAIL_USER: Your full email address (e.g. user@gmail.com)
EMAIL_USER=nafiz.movies@gmail.com
# EMAIL_PASS: This is your Google "App Password" (16 chars), NOT your login password.
EMAIL_PASS=your_app_password
# EMAIL_TO: Who should receive the alerts
EMAIL_TO=recipient_email@gmail.com

# SMTP Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
